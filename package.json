{
  "name": "accesso-ngx-daterangepicker-material",
  "version": "3.2.0",
  "description": "Angular 2+ date range picker (with material design theme)",
  "keywords": [
    "angular2",
    "angular4",
    "angular5",
    "angular6",
    "ng2",
    "daterangepicker",
    "material",
    "component",
    "directive",
    "daterange",
    "date",
    "moment",
    "picker"
  ],
  "homepage": "https://github.com/fetrarij/ngx-daterangepicker-material",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "demo:build": "ng build --prod",
    "test": "./node_modules/.bin/ng test --watch=false",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "ngc": "./node_modules/.bin/ngc -p tsconfig.json",
    "gh-pages": "ng build --prod --base-href=\"/ngx-daterangepicker-material/\" && ngh --dir demo/dist",
    "build": "ng-packagr -p package.json"
  },
  "author": "Fetrarijaona R.",
  "repository": {
    "type": "git",
    "url": "https://github.com/fetrarij/ngx-daterangepicker-material.git"
  },
  "publishConfig": {
    "registry": "https://ci.te2.biz/artifactory/api/npm/te2-npm"
  },
  "peerDependencies": {
    "moment": "^2.21.0",
    "hammerjs": "^2.0.8"
  },
  "devDependencies": {
	  "@angular-devkit/build-angular": "~0.1002.0",
	  "@angular/animations": "^10.2.3",
	  "@angular/cdk": "^10.2.7",
	  "@angular/cli": "10.2.0",
	  "@angular/common": "^10.2.3",
	  "@angular/compiler": "^10.2.3",
	  "@angular/compiler-cli": "^10.2.3",
	  "@angular/core": "^10.2.3",
	  "@angular/forms": "^10.2.3",
	  "@angular/material": "^10.2.7",
	  "@angular/platform-browser": "^10.2.3",
	  "@angular/platform-browser-dynamic": "^10.2.3",
	  "@angular/router": "^10.2.3",
	  "@types/jasmine": "~2.8.9",
	  "@types/jasminewd2": "~2.0.3",
	  "@types/node": "^12.11.1",
	  "angular-cli-ghpages": "^0.6.2",
	  "codelyzer": "6.0.1",
	  "core-js": "^2.5.4",
	  "jasmine-core": "~3.8.0",
	  "jasmine-spec-reporter": "~5.0.0",
	  "karma": "~5.0.0",
	  "karma-chrome-launcher": "~3.1.0",
	  "karma-coverage-istanbul-reporter": "~3.0.2",
	  "karma-jasmine": "~4.0.0",
	  "karma-jasmine-html-reporter": "^1.5.0",
	  "materialize-css": "^1.0.0",
	  "moment": "^2.22.2",
	  "ng-packagr": "^10.1.0",
	  "protractor": "~7.0.0",
	  "rimraf": "^2.6.1",
	  "rxjs": "^6.5.5",
	  "ts-node": "~7.0.0",
	  "tslint": "~6.1.0",
	  "typescript": "~4.0.5",
	  "zone.js": "~0.10.2"
  },
  "$schema": "./node_modules/ng-packagr/package.schema.json",
  "ngPackage": {
    "lib": {
      "entryFile": "src/daterangepicker/index.ts",
      "umdModuleIds": {
        "moment": "moment"
      }
    },
    "dest": "dist"
  },
  "dependencies": {
    "tslib": "^1.9.0"
  }
}
