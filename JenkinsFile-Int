pipeline {
	agent {
		dockerfile {
			filename 'Dockerfile'
			label 'ec2-fleet'
			additionalBuildArgs '--progress=plain --build-arg CODEARTIFACT_AUTH_TOKEN=${codeArtifactToken}'
			args '-u root --entrypoint='
		}
	}
	options {
		timestamps()
		ansiColor('xterm')
		timeout(time: 30, unit: 'MINUTES')
		buildDiscarder logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '', daysToKeepStr: '30', numToKeepStr: '10')
	}
	environment {
		CODEARTIFACT_AUTH_TOKEN = sh(script: "aws codeartifact get-authorization-token --domain passport --domain-owner 407796645946 --query authorizationToken --output text" , returnStdout: true).trim()
	}
	stages {
		stage('Build Library') {
			steps {
				sh '''
					cd /usr/src/app/dist && npm publish
				'''
			}
		}
	}
	post {
		always {
			deleteDir()
		}
	}
}
