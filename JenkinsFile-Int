pipeline {
	agent {
		dockerfile {
			filename 'Dockerfile'
			label 'ec2-fleet'
			additionalBuildArgs '--progress=plain'
			args '-u root --entrypoint='
		}
	}
	options {
		timestamps()
		ansiColor('xterm')
		timeout(time: 30, unit: 'MINUTES')
		buildDiscarder logRotator(artifactDaysToKeepStr: '', artifactNumToKeepStr: '', daysToKeepStr: '30', numToKeepStr: '10')
	}
	stages {
		stage('Build Library') {
			steps {
				configFileProvider([configFile(fileId: 'te2-artifactory-npmrc', variable: 'NPMRC_PATH')]) {
					sh '''
						# Copy the managed .npmrc file into the working directory
						cp "$NPMRC_PATH" /usr/src/app/dist/.npmrc
						
						# Ensure the file ends with a newline to avoid appending issues.
						sed -i -e '$a\\' /usr/src/app/dist/.npmrc
						
						# Export environment variable so npm uses this file as its user config.
						export NPM_CONFIG_USERCONFIG=/usr/src/app/dist/.npmrc
				
						cd /usr/src/app/dist && npm config fix && npm publish
					'''
				}
				
			}
		}
	}
	post {
		always {
			deleteDir()
		}
	}
}
